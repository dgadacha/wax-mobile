# Wax mobile — environment variables.
#
# Vite reads anything prefixed VITE_* and exposes it on import.meta.env.

# Backend base URL.
#   - Leave empty for `npm run dev` so the Vite proxy forwards /api → server.cjs
#     running on localhost:3000.
#   - Set to your deployed backend (e.g. https://wax-api.nc-maiz.org) before
#     running `npm run build && cap sync` so the Capacitor app talks to the
#     remote backend instead of a non-existent localhost.
VITE_API_BASE_URL=

# Override the dev proxy target. Defaults to http://localhost:3000.
# Useful when the backend runs on a different host on your LAN.
VITE_DEV_PROXY_TARGET=

# ─── Backend (server.cjs) ─────────────────────────────────────────
#
# Single-user login gate. When BOTH are set, every /api/* call (except
# the media proxies /api/stream, /api/cover, /api/preview,
# /api/artist-photo and the static /audio/* files) requires a Bearer
# token issued by POST /api/auth/login. Leave either empty to disable
# the gate entirely — useful for local dev. In production (k8s, public
# tunnel) you almost certainly want this set.
WAX_AUTH_EMAIL=
WAX_AUTH_PASSWORD=
