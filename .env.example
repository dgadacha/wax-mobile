# Wax mobile — environment variables.
#
# Vite reads anything prefixed VITE_* and exposes it on import.meta.env.

# Backend base URL.
#   - Leave empty for `npm run dev` so the Vite proxy forwards /api → server.cjs
#     running on localhost:3000.
#   - Set to your deployed backend (e.g. https://wax-api.nc-maiz.org) before
#     running `npm run build && cap sync` so the Capacitor app talks to the
#     remote backend instead of a non-existent localhost.
VITE_API_BASE_URL=

# Override the dev proxy target. Defaults to http://localhost:3000.
# Useful when the backend runs on a different host on your LAN.
VITE_DEV_PROXY_TARGET=

# Auth credentials — set both to enable the login gate.
# Stored in a Kubernetes secret (wax-auth) in production; set locally for dev.
WAX_AUTH_EMAIL=
WAX_AUTH_PASSWORD=

# Spotify import — create a free app at https://developer.spotify.com/dashboard
# then add your app URL (e.g. http://wax.maiz.local and http://localhost:5173)
# as a Redirect URI in the app settings.
# Client Credentials (WAX_SPOTIFY_CLIENT_SECRET) are only used by the backend
# to fetch public playlists by URL. The user-facing OAuth (liked tracks + private
# playlists) uses PKCE and only needs the Client ID.
WAX_SPOTIFY_CLIENT_ID=
WAX_SPOTIFY_CLIENT_SECRET=
